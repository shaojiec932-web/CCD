{
    "target": "esp32s3",
    "builds": [
        {
            "name": "bread-compact-wifi-lcd",
            "sdkconfig_append": [
                "CONFIG_USE_DEVICE_AEC=y",
                "CONFIG_LCD_ILI9341=y"
            ]
        },
        {
            "name": "bread-compact-wifi-lcd-ili9341-no-ips",
            "sdkconfig_append": [
                "CONFIG_USE_DEVICE_AEC=y",
                "CONFIG_LCD_ILI9341_240X320_NO_IPS=y"
            ]
        },
        {
            "name": "bread-compact-wifi-lcd-st7789",
            "sdkconfig_append": [
                "CONFIG_USE_DEVICE_AEC=y",
                "CONFIG_LCD_ST7789=y"
            ]
        },
        {
            "name": "bread-compact-wifi-lcd-st7735",
            "sdkconfig_append": [
                "CONFIG_USE_DEVICE_AEC=y",
                "CONFIG_LCD_ST7735=y"
            ]
        }
    ]
}
